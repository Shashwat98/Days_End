# Visual Studio 2015 user specific files
.vs/

# Compiled Object files
*.slo
*.lo
*.o
*.obj

# Precompiled Headers
*.gch
*.pch

# Compiled Dynamic libraries
*.so
*.dylib
*.dll

# Fortran module files
*.mod

# Compiled Static libraries
*.lai
*.la
*.a
*.lib

# Executables
*.exe
*.out
*.app
*.ipa

# These project files can be generated by the engine
*.xcodeproj
*.xcworkspace
*.sln
*.suo
*.opensdf
*.sdf
*.VC.db
*.VC.opendb

# Precompiled Assets
SourceArt/**/*.png
SourceArt/**/*.tga

# Binary Files
Binaries/*
Plugins/**/Binaries/*

# Builds
Build/*
!Build/*/
Build/*/**
!Build/*/PakBlacklist*.txt
!Build/**/*.ico

# Built data for maps
*_BuiltData.uasset

# Configuration files generated by the Editor
Saved/*

# Compiled source files for the engine to use
Intermediate/*
Plugins/**/Intermediate/*

# Cache files for the editor to use
DerivedDataCache/*

# Auto-generated Content folders
Content/__ExternalActors__/
Content/__ExternalObjects__/
Content/Collections/
Content/Developers/
Content/MSPresets/
Content/LevelPrototyping/
Content/DerivedDataCache/
Content/Saved/

# Marketplace / Downloaded Asset Packs
Content/Enemy/*
Content/Fab/*
Content/GrassMat/*
Content/Light_Foliage/*
Content/MilitaryWeapDark/*
Content/Megaplant_Library/*
Content/PostApocalypticSandbox/*
Content/Resources/*
Content/TPBDMat/*
Content/UltimateMasterMaterial/*
Content/FirstPerson/Blueprints/Enemy/FemaleZombie/*
